# Required — get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional — defaults to llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional — comma-separated allowed CORS origins
# VIBEGRAPH_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Optional — seconds before uploaded temp dirs are cleaned up (default: 3600)
# VIBEGRAPH_UPLOAD_RETENTION_SECONDS=3600
